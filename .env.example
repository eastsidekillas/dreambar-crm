# ─────────────────────────────────────────────────────────────────────
#  DreamBar — переменные окружения (продакшен)
#  Скопируйте в .env и заполните своими значениями: cp .env.example .env
# ─────────────────────────────────────────────────────────────────────

# Django
DJANGO_SECRET_KEY=ЗАМЕНИТЕ_на_длинный_случайный_ключ
DEBUG=false
# Домены через запятую (без http://). Добавьте свой домен.
ALLOWED_HOSTS=localhost,127.0.0.1

# Источники для CSRF/CORS (с http:// или https://). Нужны для входа в админку
# и если фронт на отдельном домене.
CSRF_TRUSTED_ORIGINS=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8080

# HTTPS: true — когда сайт за TLS (включает Secure cookies, HSTS, редирект).
SECURE_SSL=false

# База данных (PostgreSQL)
DATABASE_NAME=dreambar
DATABASE_USER=dreambar
DATABASE_PASSWORD=ЗАМЕНИТЕ_пароль_БД
DATABASE_ENGINE=django.db.backends.postgresql

# Порт, на котором будет доступен сайт (nginx фронтенда)
WEB_PORT=8080

# Загрузить демо-меню и сотрудников при первом старте контейнера
SEED_ON_START=true

# ── Печать чеков (термопринтер ESC/POS, напр. ATOL RP-326-USE) ──────────────
# Сами принтеры настраиваются в админке (раздел «Принтеры»). Здесь только
# кодовая страница CP866 для кириллицы. При «кракозябрах» попробуйте 6 или 7,
# либо задайте CP866 в меню принтера.
PRINTER_CODEPAGE_PAGE=17
